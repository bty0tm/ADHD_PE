  <property name="styleSheet">
   <string notr="true">/* ПРИМЕНЯЕМ ШРИФТ КО ВСЕМУ ПРИЛОЖЕНИЮ */
* {
    font-family: &quot;Intro Demo CAPS&quot;;
}

/* 1. ГЛАВНЫЙ ФОН */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #82d172, stop:1 #d7f2cb);
}

/* 2. ТЕКСТ (Жирный и коричневый) */
QLabel {
    color: #3d2500;
    font-weight: bold;
}

/* 3. БЕЛОЕ ПОЛЕ (Scroll Area) */
QScrollArea {
    background-color: white;
    border-radius: 45px;
    border: none;
}

QScrollArea &gt; QWidget &gt; QWidget {
    background-color: white;
    border-radius: 45px;
}

/* 4. ОБЩИЙ СТИЛЬ КНОПОК */
QPushButton {
    background-color: white;
    border: none;
    border-radius: 35px;
    color: #3d2500;
    font-size: 15px;
    font-weight: bold;
    min-height: 70px;
    text-align: right;
    padding-right: 40px;
    padding-left: 20px;
    /* На всякий случай дублируем шрифт здесь */
    font-family: &quot;Intro Demo CAPS&quot;;
}

QPushButton:hover {
    background-color: #F0F0F0;
}

/* 5. КНОПКА ГЕНЕРАЦИИ */
QPushButton#btn_generate {
    background-color: #457A00;
    color: #D9F4CD;
    min-width: 70px;
    max-width: 70px;
    min-height: 70px;
    max-height: 70px;
    border-radius: 35px;
    text-align: center;
    padding: 0;
    margin-left: 10px;
}

QPushButton#btn_generate:hover {
    background-color: #366100;
}

/* 6. КНОПКА &quot;НАЗАД&quot; */
QPushButton#btn_back {
    background-color: #82D172;
    border: 2px solid #3D2500;
    color: #3D2500;
    border-radius: 35px;
}

QPushButton#btn_back:hover {
    background-color: #6CBE5C;
}

/* 7. ПОЛЕ ВВОДА */
QLineEdit {
    background-color: white;
    border: none;
    border-radius: 25px;
    padding-left: 20px;
    min-height: 70px;
    color: #3d2500;
    font-size: 16px;
    font-weight: normal;
    font-family: &quot;Intro Demo CAPS&quot;;
}

/* 8. СКРОЛЛБАР */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 8px;
}
QScrollBar::handle:vertical {
    background: #82d172;
    border-radius: 4px;
}
/* 9. ЗАГОЛОВОК НА СТАРТОВОМ ЭКРАНЕ */
QLabel#title_label {
    color: #3d2500;
    font-weight: bold;
    font-size: 32px; /* Сделал покрупнее для названия */
    qproperty-alignment: 'AlignCenter'; /* Выравнивание текста строго по центру */
    background: transparent;
}

/* 10. КНОПКА &quot;НАЧАТЬ РАБОТУ&quot; */
QPushButton#btn_start_app {
    background-color: #d7f2cb;
    border: 2px solid #3d2500;
    color: #3d2500;
    border-radius: 35px;
    font-weight: bold;
    font-size: 18px;
    min-height: 70px;
    max-height: 70px;
    min-width: 250px;
    max-width: 250px;
    text-align: center; /* Текст на этой кнопке лучше по центру */
    padding-right: 0px;
}

/* Эффект при наведении на кнопку старта (на тон темнее) */
QPushButton#btn_start_app:hover {
    background-color: #bedbb1;
}


QPushButton#btn_save_time {
    background-color: #82D172;
    border: 2px solid #3D2500;
    color: #3D2500;
    border-radius: 35px;
}

QLabel#lbl_title_time {
    color: #3d2500;
    font-weight: bold;
    font-size: 32px; /* Сделал покрупнее для названия */
    qproperty-alignment: 'AlignCenter'; /* Выравнивание текста строго по центру */
    background: transparent;
}

QLabel#lbl_title {
    color: #3d2500;
    font-weight: bold;
    font-size: 32px; /* Сделал покрупнее для названия */
    qproperty-alignment: 'AlignCenter'; /* Выравнивание текста строго по центру */
    background: transparent;
}

QPushButton#btn_hint{
    text-align: center;
}

QLabel#title_name{
	qproperty-alignment: 'AlignCenter'
}

QPushButton#btn_stop_focus{
    text-align: center;
}

QLabel#label_2{
	qproperty-alignment: 'AlignCenter'
}

QLabel#label_3{
	qproperty-alignment: 'AlignCenter'
}</string>
